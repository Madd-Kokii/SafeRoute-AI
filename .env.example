# Copy this file to .env and adjust the values.

FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=120

# PostgreSQL connection string (Neon, local Docker, etc.).
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# The app auto-converts postgres:// and postgresql:// to postgresql+psycopg2://.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/saferoute

# If DATABASE_URL is omitted, the app falls back to a local SQLite file
# (backend/saferoute_dev.db) so it runs without provisioning PostgreSQL.

# Seed admin credentials (used by `flask seed`).
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@saferoute.ai
SEED_ADMIN_PASSWORD=Admin#12345

# Safety Assistant — Serper real-time Google search for South Africa (recommended)
SERPER_API_KEY=
# Optional LLM layer (OpenAI / OpenRouter) — separate key from Serper
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=openai/gpt-4o-mini
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# CHAT_AI_ENABLED=true
